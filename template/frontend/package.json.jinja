{
    "name": "{{ project_name }}",
    "version": "{{ project_version }}",
    "description": "{{ project_description }}",
    "keywords": [
        "{{ project_keywords.split(',')|join('",\n"') }}"
    ],
    "author": {
        "name": "{{ copyright_holder_name }}",
        "email": "{{ copyright_holder_email }}"
    },
    "homepage": "https://github.com/{{ vcs_github_path }}#readme",
    "bugs": {
        "url": "https://github.com/{{ vcs_github_path }}/issues",
        "email": "{{ copyright_holder_email }}"
    },
    "license": "{{ copyright_license }}",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/{{ vcs_github_path }}.git"
    },
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "check": "biome check src/",
        "check:fix": "biome check --write .",
        "format": "biome format --write .",
        "typecheck": "vue-tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "vue": "^3.5.35",
        "vue-router": "^5.1.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.0",
        "@vitejs/plugin-vue": "^6.0.7",
        "@vitest/coverage-v8": "^4.1.8",
        "@vue/test-utils": "^2.4.11",
        "jsdom": "^29.1.1",
        "typescript": "^6.0.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.8",
        "vue-tsc": "^3.3.3"
    },
    "engines": {
        "node": ">=22"
    },
    "private": true,
    "packageManager": "pnpm@11.6.0"
}
